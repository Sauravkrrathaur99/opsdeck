PORT=3847
# NEVER use 0.0.0.0 without OPSDECK_ACCESS_TOKEN — binds to localhost only by default
HOST=127.0.0.1

# Encrypts stored SSH passwords/keys in SQLite (24+ random chars for production)
MASTER_KEY=change-this-to-a-long-random-secret

# REQUIRED before exposing OpsDeck on a network — login gate for the whole app
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPSDECK_ACCESS_TOKEN=
