# =============================================================================
# OpsDeck — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values before running OpsDeck.
#
#   Windows (PowerShell):  Copy-Item .env.example .env
#   macOS / Linux:         cp .env.example .env
#
# Generate secure random secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HTTP port for the OpsDeck API and web UI (default: 3847)
PORT=3847

# Bind address — keep 127.0.0.1 for local-only access (recommended)
# NEVER use 0.0.0.0 without setting OPSDECK_ACCESS_TOKEN below
HOST=127.0.0.1


# -----------------------------------------------------------------------------
# Security (required before exposing OpsDeck on a network)
# -----------------------------------------------------------------------------

# Encrypts SSH passwords and private keys stored in the local SQLite database
# Minimum 24 characters for production use
MASTER_KEY=change-this-to-a-long-random-secret-at-least-24-chars

# Login password for OpsDeck — required when HOST is not localhost
# Minimum 16 characters; users must enter this to unlock the app
# Leave empty for localhost-only dev (no login screen)
OPSDECK_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Desktop installer build (optional — team lead only)
# -----------------------------------------------------------------------------
# Embed a shared access token into the Windows installer at build time.
# Set only when running: npm run desktop:build
# Do NOT commit real tokens — use your shell environment instead.
#
# OPSDECK_BUILD_TOKEN=your-shared-team-access-token
